    "browser-python"
  ],
  "author": "Aswanth R (NodeX-AR)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nodex-ar/pytml.git"
  },
  "bugs": {
    "url": "https://github.com/nodex-ar/pytml/issues"
  },
  "homepage": "https://github.com/nodex-ar/pytml#readme",
  "files": [
    "pytml.js",
    "pytml.min.js",
    "worker.js",
    "worker.min.js",
    "README.md"
  ],
  "devDependencies": {
    "uglify-js": "^3.17.4"
  }
}
