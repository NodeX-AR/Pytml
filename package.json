{
  "name": "pytml",
  "version": "3.1.0",
  "description": "Python in HTML - Client-side Python execution like JavaScript",
  "main": "pytml.js",
  "unpkg": "pytml.min.js",
  "jsdelivr": "pytml.min.js",
  "scripts": {
    "build": "uglifyjs pytml.js -o pytml.min.js && uglifyjs worker.js -o worker.min.js",
    "test": "node test.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "python",
    "html",
    "webassembly",
    "pyodide",
