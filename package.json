  "description": "Python in HTML - Write Python directly in your browser like JavaScript",
  "main": "pytml.js",
  "unpkg": "pytml.min.js",
  "jsdelivr": "pytml.min.js",
  "scripts": {
    "build": "uglifyjs pytml.js -o pytml.min.js",
    "prepublishOnly": "npm run build"
