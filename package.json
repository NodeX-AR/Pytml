  ],
  "author": "NodeX-AR",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NodeX-AR/Pytml.git"
  },
  "bugs": {
    "url": "https://github.com/NodeX-AR/Pytml/issues"
  },
  "homepage": "https://github.com/NodeX-AR/Pytml#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "pytml.js",
    "pytml.min.js",
    "worker.js",
    "README.md"
  ],
  "devDependencies": {
    "uglify-js": "^3.17.4"
